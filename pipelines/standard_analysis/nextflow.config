/*
========================================================================================
    Standard Analysis Pipeline - Nextflow Configuration
========================================================================================
*/

// Pipeline metadata
manifest {
    name            = 'standard_analysis'
    author          = 'McCarroll Lab'
    homePage        = 'https://github.com/broadinstitute/mccarroll_nextflow'
    description     = 'Single-cell RNA-seq standard analysis pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}

// Default parameters
params {
    // Input files (required)
    dge_loom            = null
    sample_name         = null
    individual_names    = null
    annotation_gtf      = null
    sex_gene_names      = null
    
    // Analysis parameters (required)
    nref                = null
    num_downsample      = null
    
    // Optional parameters with defaults
    bead_synthesis_error_rate = 0.2
    bead_synthesis_size       = 2000000
    dge_loom_extra            = null
    
    // Output directory
    output_dir          = './results'
    
    // Max resource limits
    max_cpus            = 16
    max_memory          = 128.GB
    max_time            = 240.h
    
    // Help
    help                = false
}

// Process configuration
process {
    // Default resources
    cpus   = 1
    memory = 6.GB
    time   = 4.h
    
    // Error strategy
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'
    
    // Process-specific resources
    withName: 'SUBSET_DIGITAL_EXPRESSION' {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }
    
    withName: 'GATHER_MOLECULE_BARCODES_BY_GENE' {
        cpus   = 4
        memory = 16.GB
        time   = 4.h
    }
    
    withName: 'CREATE_INTERVALS' {
        cpus   = 2
        memory = 4.GB
        time   = 1.h
    }
    
    withName: 'COLLAPSE_BARCODE_CHIMERIC_TRANSCRIPTS' {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }
    
    withName: 'TRANSCRIPT_DOWNSAMPLING' {
        cpus   = 2
        memory = 12.GB
        time   = 4.h
    }
    
    withName: 'GATHER_TRANSCRIPT_DOWNSAMPLING_PLOTS' {
        cpus   = 1
        memory = 4.GB
        time   = 1.h
    }
    
    withName: 'DISCOVER_META_GENES' {
        cpus   = 4
        memory = 32.GB
        time   = 8.h
    }
    
    withName: 'ASSIGN_CELLS_TO_SAMPLES' {
        cpus   = 4
        memory = 24.GB
        time   = 8.h
    }
    
    withName: 'DROPULATION_PLOT' {
        cpus   = 1
        memory = 4.GB
        time   = 1.h
    }
    
    withName: 'DETECT_DOUBLETS' {
        cpus   = 4
        memory = 24.GB
        time   = 8.h
    }
    
    withName: 'SEX_GENOTYPES' {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }
}

// Execution profiles
profiles {
    // Standard profile (default)
    standard {
        process.executor = 'local'
    }
    
    // Docker profile
    docker {
        docker.enabled = true
        process.container = 'ubuntu:20.04'
    }
    
    // Singularity profile
    singularity {
        singularity.enabled = true
        process.container = 'docker://ubuntu:20.04'
    }
    
    // AWS Batch profile
    awsbatch {
        process.executor = 'awsbatch'
        process.queue = 'default'
        aws.region = 'us-east-1'
    }
    
    // Google Cloud profile
    gcp {
        process.executor = 'google-batch'
        google.region = 'us-central1'
    }
    
    // Slurm profile
    slurm {
        process.executor = 'slurm'
        process.queue = 'normal'
    }
}

// Report configuration
report {
    enabled = true
    file    = "${params.output_dir}/reports/execution_report.html"
}

timeline {
    enabled = true
    file    = "${params.output_dir}/reports/timeline.html"
}

trace {
    enabled = true
    file    = "${params.output_dir}/reports/trace.txt"
}

dag {
    enabled = true
    file    = "${params.output_dir}/reports/pipeline_dag.html"
}
